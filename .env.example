# Copy this file to .env and fill in your values.
# Never commit .env — it is in .gitignore.

# Supabase
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_JWT_AUDIENCE=authenticated

# AI (OpenRouter)
OPENROUTER_API_KEY=sk-or-...

# MLS data — optional, Perplexity is used as fallback if not set
BRIDGE_SERVER_KEY=

# Frontend build output path (default: webapp/dist)
FRONTEND_DIST=webapp/dist

# Federal Reserve (FRED) API — optional, used for live mortgage rates in the webapp
# Free key: https://fred.stlouisfed.org/docs/api/api_key.html
# Falls back to hardcoded estimates if not set
VITE_FRED_API_KEY=
