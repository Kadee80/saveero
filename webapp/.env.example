# Copy this file to webapp/.env — never commit .env.
# These are frontend (Vite) env vars — all must start with VITE_.

# ── Supabase (frontend) ────────────────────────────────────────────────────────
# Settings → API → Project URL
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
# Settings → API → anon/public key (safe to expose in the browser)
VITE_SUPABASE_ANON_KEY=

# ── Federal Reserve (FRED) API ─────────────────────────────────────────────────
# Optional — live mortgage rates. Free key: https://fred.stlouisfed.org/docs/api/api_key.html
# Falls back to hardcoded estimates if not set.
VITE_FRED_API_KEY=
